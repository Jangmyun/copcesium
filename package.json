{
  "name": "copcesium",
  "version": "1.0.0",
  "description": "CesiumJS provider for real-time COPC point cloud streaming and rendering",
  "type": "module",
  "license": "MIT",
  "main": "./dist/copc-cesium.cjs",
  "module": "./dist/copc-cesium.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/copc-cesium.mjs",
      "require": "./dist/copc-cesium.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"demo/**/*.ts\"",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jangmyun/copcesium.git"
  },
  "keywords": [
    "cesium",
    "copc",
    "point-cloud",
    "las",
    "laz",
    "webgl"
  ],
  "author": "",
  "bugs": {
    "url": "https://github.com/Jangmyun/copcesium/issues"
  },
  "homepage": "https://github.com/Jangmyun/copcesium#readme",
  "peerDependencies": {
    "cesium": ">=1.100.0"
  },
  "dependencies": {
    "copc": "^0.0.8",
    "proj4": "^2.20.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "@types/proj4": "^2.5.6",
    "@vitest/ui": "^4.1.10",
    "cesium": "^1.143.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-cesium": "^1.2.23",
    "vitest": "^4.1.10"
  }
}
